# =============================================================================
# ANFITRIÃO — Variáveis de ambiente do front (Vite / Vercel)
#
# Copie para .env.local em desenvolvimento, e cole na Vercel em
#   Project → Settings → Environment Variables   (Production + Preview)
#
# Sem nenhuma destas variáveis o app roda em modo MOCK (dados simulados).
# Defina o conjunto correspondente para ativar a integração real.
# =============================================================================

# --- Chatwoot ---
VITE_CHATWOOT_URL=https://chat.suaempresa.com.br
VITE_CHATWOOT_USER_TOKEN=        # Profile Settings → Access Token
VITE_CHATWOOT_ACCOUNT_ID=1
VITE_CHATWOOT_INBOX_ID=1
VITE_CHATWOOT_PUBSUB_TOKEN=      # Token de subscription do ActionCable

# --- Dify (RAG) ---
VITE_DIFY_URL=https://dify.suaempresa.com.br
VITE_DIFY_API_KEY=               # App → API Access → Service API key
VITE_DIFY_DATASET_ID=            # Knowledge → Settings → Dataset ID
