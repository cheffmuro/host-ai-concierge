# Overrides opcionais do Dify (copiar trechos para o .env raiz se necessário).
# A maioria das variáveis principais já vive no docker-compose.yml.

# Storage local (default). Para S3, definir:
# STORAGE_TYPE=s3
# S3_ENDPOINT=
# S3_BUCKET_NAME=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=

# Vector store (default: weaviate embutido). Para Qdrant externo:
# VECTOR_STORE=qdrant
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=
