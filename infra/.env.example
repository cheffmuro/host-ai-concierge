# ====== Domínio base (subdomínios serão chatwoot./dify./evo.) ======
BASE_DOMAIN=suaempresa.com.br

# ====== Postgres compartilhado ======
POSTGRES_USER=host-ai-concierge
POSTGRES_PASSWORD=trocar-senha-forte

# ====== Redis compartilhado ======
REDIS_PASSWORD=trocar-senha-forte

# ====== Chatwoot ======
# Gere com: openssl rand -hex 64
CHATWOOT_SECRET_KEY_BASE=

# ====== Dify ======
# Gere com: openssl rand -base64 42
DIFY_SECRET_KEY=
DIFY_SANDBOX_API_KEY=trocar-key-sandbox
# Origins liberados (front Vercel + domínio custom). Separar por vírgula.
DIFY_CORS_ORIGINS=https://host-ai-concierge.vercel.app,https://app.suaempresa.com.br

# ====== Evolution API (WhatsApp) ======
EVOLUTION_API_KEY=trocar-key-evolution
